<?xml version="1.0" encoding="UTF-8"?>
<!--
	Fake player behavior + procedural population.

	PROFILES define HOW a bot moves:
	  WANDER - random hops within its radius of the home anchor (idling / milling about).
	  VISIT  - walks to a RANDOM point of interest from its <point> list, idles a long time on arrival,
	           then moves to another: this is "purposeful" movement between gatekeeper / warehouse / shops.
	  PATROL - walks the <point> list in order, looping.
	  For procedurally deployed bots the wander radius comes from their <population> (so cluster
	  tightness is set per group); the profile "radius" is only a fallback for discovered bots.

	POPULATIONS define WHERE / HOW MANY / WHAT:
	  count, x/y/z (anchor center), radius (scatter + wander; small = tight cluster),
	  minLevel/maxLevel (drives gear tier: most bots are poor/average, only a few fully kitted),
	  profile, and optional race (a dominant race for the group, e.g. a Dwarven village).

	Coordinates are taken from the datapack (town respawn points and Giran NPC spawns).

	Tuning intent: most bots IDLE in clusters (the majority around the gatekeeper), a minority MOVE
	with purpose. Starting villages are kept small and race-appropriate.
-->
<list xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="xsd/FakePlayerBehavior.xsd">
	<!-- ===== Movement profiles ===== -->
	<!-- Idlers: stand around a spot, only shuffle occasionally. -->
	<profile name="loiter" type="WANDER" radius="150" run="false" pauseMin="25" pauseMax="80" />
	<!-- Light movers: amble around an area. -->
	<profile name="mill" type="WANDER" radius="350" run="false" pauseMin="18" pauseMax="45" />
	<!-- Purposeful movers in Giran: walk between the key NPCs, lingering at each. -->
	<profile name="visit_giran" type="VISIT" run="false" pauseMin="25" pauseMax="70">
		<point x="83485" y="147998" z="-3407" /> <!-- Gatekeeper -->
		<point x="83192" y="146680" z="-3464" /> <!-- Warehouse -->
		<point x="82651" y="146714" z="-3466" /> <!-- Dimensional Merchants -->
		<point x="85055" y="146560" z="-3399" /> <!-- Blacksmith / weapon shops -->
		<point x="85505" y="146208" z="-3399" /> <!-- Grocer -->
		<point x="81360" y="150016" z="-3528" /> <!-- Mammon -->
	</profile>
	<!-- Roams wide at a run: fallback profile for discovered hand-placed fake players. -->
	<profile name="farmer" type="WANDER" radius="1400" run="true" pauseMin="3" pauseMax="9" />
	<!-- Hunters: seek the nearest monster in the zone, fight it, then roam to find more. -->
	<profile name="hunter" type="FARM" run="true" pauseMin="2" pauseMax="6" />

	<!-- ===== GIRAN (~145): mostly idlers clustered on NPCs, the majority at the gatekeeper ===== -->
	<population name="giran_gatekeeper" count="38" x="83485" y="147998" z="-3407" radius="240" minLevel="1" maxLevel="76" profile="loiter" />
	<population name="giran_warehouse" count="14" x="83192" y="146680" z="-3464" radius="200" minLevel="1" maxLevel="76" profile="loiter" />
	<population name="giran_merchants" count="12" x="82651" y="146714" z="-3466" radius="200" minLevel="1" maxLevel="60" profile="loiter" />
	<population name="giran_blacksmith" count="12" x="85055" y="146560" z="-3399" radius="200" minLevel="15" maxLevel="76" profile="loiter" />
	<population name="giran_grocer" count="10" x="85505" y="146208" z="-3399" radius="180" minLevel="1" maxLevel="50" profile="loiter" />
	<population name="giran_mammon" count="10" x="81360" y="150016" z="-3528" radius="180" minLevel="20" maxLevel="76" profile="loiter" />
	<!-- The minority that move with purpose between the above. -->
	<population name="giran_movers" count="26" x="83485" y="147998" z="-3407" radius="300" minLevel="15" maxLevel="76" profile="visit_giran" />
	<!-- A little background milling in the square. -->
	<population name="giran_crowd" count="22" x="83400" y="147600" z="-3400" radius="900" minLevel="15" maxLevel="50" profile="mill" />
	<!-- Private-shop market: seated vendors with WTS/WTB store signs (visual stores). -->
	<population name="giran_market_sell" count="30" x="83400" y="147300" z="-3400" radius="500" minLevel="20" maxLevel="62" profile="loiter" store="SELL" />
	<population name="giran_market_buy" count="12" x="83400" y="147300" z="-3400" radius="500" minLevel="20" maxLevel="62" profile="loiter" store="BUY" />
	<population name="giran_gk_vendors" count="10" x="83485" y="147998" z="-3407" radius="260" minLevel="20" maxLevel="62" profile="loiter" store="SELL" />

	<!-- ===== Starting villages: small, race-appropriate, clustered at the gatekeeper ===== -->
	<!-- Talking Island (Humans) -->
	<population name="ti_gatekeeper" count="9" x="-83990" y="243336" z="-3700" radius="220" minLevel="1" maxLevel="18" profile="loiter" race="HUMAN" />
	<population name="ti_movers" count="3" x="-83990" y="243336" z="-3700" radius="450" minLevel="1" maxLevel="18" profile="mill" race="HUMAN" />
