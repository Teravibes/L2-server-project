	<population name="elf_gatekeeper" count="8" x="46926" y="51511" z="-2976" radius="220" minLevel="1" maxLevel="20" profile="loiter" race="ELF" />
	<population name="elf_movers" count="2" x="46926" y="51511" z="-2976" radius="450" minLevel="1" maxLevel="20" profile="mill" race="ELF" />
	<!-- Dark Elven Village -->
	<population name="delf_gatekeeper" count="8" x="12501" y="16768" z="-4500" radius="220" minLevel="1" maxLevel="20" profile="loiter" race="DARK_ELF" />
	<population name="delf_movers" count="2" x="12501" y="16768" z="-4500" radius="450" minLevel="1" maxLevel="20" profile="mill" race="DARK_ELF" />
	<!-- Dwarven Village (anchored on Gatekeeper Wirphy; crowd stays mostly at the gatekeeper) -->
	<population name="dwarf_gatekeeper" count="11" x="115072" y="-178176" z="-880" radius="200" minLevel="1" maxLevel="20" profile="loiter" race="DWARF" />
	<population name="dwarf_movers" count="2" x="115072" y="-178176" z="-880" radius="400" minLevel="1" maxLevel="20" profile="mill" race="DWARF" />
	<!-- Orc Village -->
	<population name="orc_gatekeeper" count="8" x="-44316" y="-113136" z="-80" radius="220" minLevel="1" maxLevel="20" profile="loiter" race="ORC" />
	<population name="orc_movers" count="2" x="-44316" y="-113136" z="-80" radius="450" minLevel="1" maxLevel="20" profile="mill" race="ORC" />

	<!-- ===== Gludin & Gludio: mixed-race hubs, a bit larger ===== -->
	<population name="gludin_gatekeeper" count="12" x="-83520" y="150560" z="-3000" radius="260" minLevel="1" maxLevel="30" profile="loiter" />
	<population name="gludin_movers" count="5" x="-83520" y="150560" z="-3000" radius="600" minLevel="1" maxLevel="30" profile="mill" />
	<population name="gludio_gatekeeper" count="14" x="-14288" y="122752" z="-3000" radius="260" minLevel="5" maxLevel="35" profile="loiter" />
	<population name="gludio_movers" count="5" x="-14288" y="122752" z="-3000" radius="600" minLevel="5" maxLevel="35" profile="mill" />

	<!-- ===== Field / farming zones (hunters seek monsters and roam the zone; respawn keeps them populated)
	     Coordinates are real zone vertices from the datapack; with geodata loaded the Z snaps to ground.
	     The wide radius + FARM behavior spreads bots across the zone instead of clustering at one spot.
