<?xml version="1.0" encoding="UTF-8"?>
<!--
	Fake player behavior + procedural population.

	PROFILES define HOW a bot moves (WANDER random hops, or PATROL a waypoint loop) and its pacing.
	  - The wander radius for procedurally deployed bots comes from their <population>, not the profile;
	    the profile's "radius" is only a fallback for hand-placed fake players discovered in the world.

	POPULATIONS define WHERE and HOW MANY bots to procedurally spawn:
	  count    - how many bots to deploy in this group.
	  x/y/z    - the anchor center (a town square, or a specific NPC's location for a cluster).
	  radius   - bots scatter within this distance and wander within it, anchored to the center,
	             so a small radius = a tight cluster around the spot.
	  minLevel / maxLevel - level range rolled per bot (drives gear tier: no-grade <20, D 20-39, C 40+).
	  profile  - which movement profile the group uses.

	All coordinates below were taken from the server's own datapack (town respawn points and
	Giran NPC spawns), so they are valid ground.
-->
<list>
	<!-- ===== Movement profiles ===== -->
	<!-- Stands around a spot, only shuffles occasionally: for NPC clusters. -->
	<profile name="loiter" type="WANDER" radius="250" run="false" pauseMin="15" pauseMax="45" />
	<!-- General town life: strolls around at a walk. -->
	<profile name="townsfolk" type="WANDER" radius="800" run="false" pauseMin="8" pauseMax="25" />
	<!-- Moves more often, covers more ground (busy capital streets). -->
	<profile name="stroller" type="WANDER" radius="1400" run="false" pauseMin="5" pauseMax="15" />
	<!-- Roams wide at a run and engages monsters: for future field/farming zones. -->
	<profile name="farmer" type="WANDER" radius="1400" run="true" pauseMin="3" pauseMax="9" />

	<!-- ===== GIRAN: the capital (~220), with clusters around key NPCs + a roaming crowd ===== -->
	<!-- Clusters: a tight knot of people standing around a specific NPC. -->
	<population name="giran_gatekeeper" count="18" x="83485" y="147998" z="-3407" radius="260" minLevel="1" maxLevel="76" profile="loiter" />
	<population name="giran_warehouse" count="12" x="83192" y="146680" z="-3464" radius="220" minLevel="1" maxLevel="76" profile="loiter" />
	<population name="giran_mammon" count="10" x="81360" y="150016" z="-3528" radius="220" minLevel="20" maxLevel="76" profile="loiter" />
	<population name="giran_merchants" count="10" x="82651" y="146714" z="-3466" radius="220" minLevel="1" maxLevel="60" profile="loiter" />
	<population name="giran_grocer" count="8" x="85505" y="146208" z="-3399" radius="220" minLevel="1" maxLevel="50" profile="loiter" />
	<!-- The moving crowd that fills the square and streets. -->
	<population name="giran_square" count="140" x="83400" y="147600" z="-3400" radius="1300" minLevel="15" maxLevel="60" profile="townsfolk" />
	<population name="giran_streets" count="24" x="82480" y="149087" z="-3350" radius="1600" minLevel="20" maxLevel="76" profile="stroller" />

	<!-- ===== Starting villages + Gludio (lower level, modest crowds) ===== -->
	<population name="talking_island" count="28" x="-83990" y="243336" z="-3700" radius="900" minLevel="1" maxLevel="20" profile="townsfolk" />
	<population name="gludin" count="28" x="-83520" y="150560" z="-3000" radius="900" minLevel="1" maxLevel="25" profile="townsfolk" />
	<population name="gludio" count="28" x="-14288" y="122752" z="-3000" radius="900" minLevel="5" maxLevel="30" profile="townsfolk" />
	<population name="dwarven_village" count="20" x="116176" y="-182448" z="-1400" radius="700" minLevel="1" maxLevel="20" profile="townsfolk" />
	<population name="orc_village" count="20" x="-44316" y="-113136" z="-80" radius="700" minLevel="1" maxLevel="20" profile="townsfolk" />

	<!-- ===== Per-bot assignments for hand-placed fake players (discovered in the world) ===== -->
	<assign name="Theron" profile="farmer" />
	<assign name="Lytheris" profile="townsfolk" />

	<!-- Fallback profile for any discovered fake player without an explicit assignment. -->
	<default profile="townsfolk" />
</list>
